import matplotlib.pyplot as plt
x = [1, 0, 5, 1]
y = [6, 8, 3, 6]
x_shear = [x[i] + 5*y[i] for i in range(len(x))]
y_shear = y
x_ref = [-i for i in x_shear]
x_trans = [i + 1 for i in x_ref]
y_trans = [i + 4 for i in y_shear]
plt.plot(x, y, label="Original")
plt.plot(x_shear, y_shear, label="Sheared")
plt.plot(x_ref, y_shear, label="Reflected")
plt.plot(x_trans, y_trans, label="Translated")
plt.legend()
plt.title("Transformations")
plt.show() 
