Question 1-4

from sympy import Point, Polygon
import math

points = []
n = 5
r = 4

for i in range(n):
    angle = 2*math.pi*i/n
    points.append(Point(r*math.cos(angle), r*math.sin(angle)))

poly = Polygon(*points)

print("Area:", poly.area)

# Scaling (x*3, y*2)
scaled = [Point(p.x*3, p.y*2) for p in poly.vertices]
print("Scaled:", scaled)


