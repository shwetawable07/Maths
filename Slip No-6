y = x**2 + 5
plt.plot(x, y, 'ro-') # red with marker
plt.arrow(0, 0, 5, 0, head_width=2, color='black')
plt.arrow(0, 0, 0, 50, head_width=2, color='black')
plt.xlabel("x")
plt.ylabel("y")
plt.title("y = x^2 + 5")
plt.show()


