Question 2-1

import numpy as np
import matplotlib.pyplot as plt

points = np.array([[1,6],[0,8],[5,3]])

# Shearing (x-direction by 5*y)
shear = np.array([[1,5],[0,1]])
sheared = np.dot(points, shear)

# Reflection y-axis
reflected = sheared * [-1,1]

# Translation (+1, +4)
translated = reflected + [1,4]

def plot_shape(p, label):
    p = np.vstack([p, p[0]])
    plt.plot(p[:,0], p[:,1], label=label)

plot_shape(points, "Original")
plot_shape(translated, "Transformed")

plt.legend()
plt.show()


