import numpy as np
import matplotlib.pyplot as plt
x1 = np.linspace(-10, 10, 100)
y1 = x1**2
x2 = np.linspace(1, 20, 100)
y2 = np.exp(2*x2 + 4)
plt.subplot(1, 2, 1)
plt.plot(x1, y1)
plt.title("f(x) = x^2")
plt.subplot(1, 2, 2)
plt.plot(x2, y2)
plt.title("g(x) = e^(2x+4)")
plt.tight_layout()
plt.show() 


