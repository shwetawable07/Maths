import numpy as np
import matplotlib.pyplot as plt

# Data
x1 = np.linspace(-5, 5, 100)
y1 = x1**3

x2 = np.linspace(1, 10, 100)
y2 = np.exp(x2)

# Subplots (2 rows, 1 column)
plt.subplot(2,1,1)
plt.plot(x1, y1)
plt.title("f(x) = x^3")

plt.subplot(2,1,2)
plt.plot(x2, y2)
plt.title("g(x) = e^x")

plt.tight_layout()
plt.show()



