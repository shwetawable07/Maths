import sympy as sp

P = sp.Point(2, -1, 3)

# Rotation matrix (90° about Z-axis)
theta = sp.pi/2
R = sp.Matrix([[sp.cos(theta), -sp.sin(theta), 0],
               [sp.sin(theta),  sp.cos(theta), 0],
               [0, 0, 1]])

rotated = R * sp.Matrix(P)

print("Rotated Point:", rotated)



Question No 2-1

import numpy as np
import matplotlib.pyplot as plt

points = np.array([[-2,7], [-5,-1], [4,3]])

# Shearing
shear = np.dot(points, [[1,3],[4,1]])

# Reflection (x-axis)
reflect = shear * [1,-1]

# Translation (y +7)
translate = reflect + [0,7]

def plot_shape(p, label):
    p = np.vstack([p, p[0]])
    plt.plot(p[:,0], p[:,1], label=label)

plot_shape(points, "Original")
plot_shape(translate, "Transformed")

plt.legend()
plt.show()



