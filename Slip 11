Question 2-1

import matplotlib.pyplot as plt
import numpy as np
A = np.array([10,5])
B = np.array([-7,4])
C = np.array([8,-3])
triangle = np.array([A,B,C,A])
reflected = triangle.copy()
reflected[:,0] = -reflected[:,0]
rotation_matrix = np.array([[0,-1],[1,0]])
rotated = reflected.dot(rotation_matrix)
scaled = rotated * 7
plt.plot(triangle[:,0], triangle[:,1], label="Original")
plt.plot(scaled[:,0], scaled[:,1], label="Transformed")
plt.legend()
plt.title("Triangle Transformation")
plt.show()




