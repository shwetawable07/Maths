Question 1-2

import numpy as np
import matplotlib.pyplot as plt
x = np.linspace(0, np.pi/2, 100)
y = x**2 + np.cos(2*x + 5)
plt.plot(x, y, color='red')
plt.annotate('', xy=(x[-1], y[-1]), xytext=(x[-2], y[-2]),
             arrowprops=dict(arrowstyle='->', color='red'))
plt.xlabel('x')
plt.ylabel('y')
plt.title('y = x^2 + cos(2x + 5)')
plt.show()


