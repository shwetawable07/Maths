from sympy import symbols, Eq, solve
import math
x, y = symbols('x y')
eq1 = Eq(3*x + 5*y, 4)
eq2 = Eq(x - 5*y, 8)
solution = solve((eq1, eq2), (x, y))
print("Intersection Point:", solution)
m1 = -3/5
m2 = 1/5
angle = math.degrees(math.atan(abs((m2 - m1)/(1 + m1*m2))))
