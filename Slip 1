from sympy import Point, Line
P = Point(7, 2)
Q = Point(1, 8)
distance = P.distance(Q)
print("Distance:", distance)
line = Line(P, Q)
print("Line:", line)
slope = line.slope
print("Slope:", slope)
equation = line.equation()
print("Equation of line:", equation)


