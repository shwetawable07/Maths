import matplotlib.pyplot as plt
x = [4, 6, 6, 4, 4] y = [3, 3, 5, 5, 3]
y_reflect_x = [-i for i in y]
x_reflect_y = [-i for i in x]
plt.plot(x, y, label="Original")
plt.plot(x, y_reflect_x, label="X-axis Reflection")
plt.plot(x_reflect_y, y, label="Y-axis Reflection")
plt.axhline(0, color='black')
plt.axvline(0, color='black')
plt.legend()
plt.title("Polygon Reflection")
plt.show()







