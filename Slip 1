import matplotlib.pyplot as plt
x = [4,6,6,4,4]
y = [3,3,5,5,3]
y_ref = [-i for i in y]
x_ref = [-i for i in x]
plt.plot(x, y, label="Original")
plt.plot(x, y_ref, label="X-axis reflection")
plt.plot(x_ref, y, label="Y-axis reflection")
plt.axhline(0)
plt.axvline(0)
plt.legend()
plt.show()



