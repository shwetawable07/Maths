Question No 2-1


import matplotlib.pyplot as plt
import numpy as np

# Original points
points = np.array([[1,1], [-5,1], [-5,-4], [1,-4]])

# Rotation 90°
rotation_matrix = np.array([[0, -1], [1, 0]])
rotated = np.dot(points, rotation_matrix)

# Shearing (x-direction by factor 3)
shear_matrix = np.array([[1, 3], [0, 1]])
sheared = np.dot(points, shear_matrix)

# Plot
plt.plot(*zip(*(list(points)+[points[0]])), label="Original")
plt.plot(*zip(*(list(rotated)+[rotated[0]])), label="Rotated")
plt.plot(*zip(*(list(sheared)+[sheared[0]])), label="Sheared")

plt.legend()
plt.show()



