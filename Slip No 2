from sympy import Point

P = Point(-4, 5)

# Scaling x by 2
scale = Point(P.x*2, P.y)

# Reflection through y=x
reflect = Point(P.y, P.x)

# Translation y + 7
translate = Point(P.x, P.y + 7)

print("Scaling:", scale)
print("Reflection:", reflect)
print("Translation:", translate)



