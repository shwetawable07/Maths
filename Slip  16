Question 2-1

import matplotlib.pyplot as plt
import numpy as np
points = np.array([[1, 2], [4, 2], [4, 4], [2, 5]])
points = np.vstack([points, points[0]])
shx = 3
shy = -2
sheared = []
for x, y in points:
    x_new = x + shx * y
    y_new = y + shy * x
    sheared.append([x_new, y_new])
sheared = np.array(sheared)
plt.plot(points[:,0], points[:,1], label="Original")
plt.plot(sheared[:,0], sheared[:,1], label="Sheared")
plt.axhline(0)
plt.axvline(0)
plt.legend()
plt.grid()
plt.show()




