from sympy import Point, Triangle
P = Point(1, 1)
Q = Point(5, 1)
R = Point(5, 5)
tri = Triangle(P, Q, R)
print("Area:", tri.area)
print("Circumcircle:", tri.circumcircle)
print("Right angled:", tri.is_right())
P_new = Point(P.x*2, P.y*4)
