import numpy as np
import matplotlib.pyplot as plt

x = np.linspace(-10, -2, 100)
y = np.sqrt((x**2/16 - 1)*9)

plt.plot(x, y)
plt.plot(x, -y)

x2 = np.linspace(2, 10, 100)
y2 = np.sqrt((x2**2/16 - 1)*9)

plt.plot(x2, y2)
plt.plot(x2, -y2)

plt.title("Hyperbola x^2/16 - y^2/9 = 1")
plt.show()

























































