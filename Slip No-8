Question 2-1

import numpy as np
import matplotlib.pyplot as plt

points = np.array([[2,1],[4,1],[3,4]])

# Rotation (90°)
theta = np.pi/2
rot = np.dot(points, [[np.cos(theta), -np.sin(theta)],
                      [np.sin(theta),  np.cos(theta)]])

# Scaling (2,2)
scaled = rot * 2

# Reflection (x-axis)
reflected = scaled * [1,-1]

def plot_shape(p, label):
    p = np.vstack([p, p[0]])
    plt.plot(p[:,0], p[:,1], label=label)

plot_shape(points, "Original")
plot_shape(reflected, "Transformed")

plt.legend()
plt.show()



