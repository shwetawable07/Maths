Question 2-1

import numpy as np
import matplotlib.pyplot as plt
triangle = np.array([[4,4],[2,4],[4,2]])
theta = np.pi/2
rotation = np.array([[np.cos(theta), -np.sin(theta)],
                     [np.sin(theta),  np.cos(theta)]])
rotated = np.dot(triangle, rotation)
scaled = rotated * 3
def plot_shape(points, label):
    pts = list(points) + [points[0]]
    x, y = zip(*pts)
    plt.plot(x, y, label=label)
plot_shape(triangle, "Original")
plot_shape(rotated, "Rotated")
plot_shape(scaled, "Scaled")
plt.axhline(0)
plt.axvline(0)
plt.legend()
plt.grid()
plt.title("Triangle Transformation")
plt.show()





