import numpy as np
import matplotlib.pyplot as plt
points = np.array([[1,1],[1,4],[4,1],[4,4]])
shx = 3
shy = 7
shear_matrix = np.array([[1, shx],
                         [shy, 1]])
transformed = np.dot(points, shear_matrix)
plt.plot(*zip(*(list(points)+[points[0]])), label='Original')
plt.plot(*zip(*(list(transformed)+[transformed[0]])), label='Sheared')
plt.legend()
plt.grid()
plt.title("Shearing Transformation")
plt.show()




