Question 2-1

import numpy as np
import matplotlib.pyplot as plt
A = np.array([0,3])
B = np.array([-3,3])
C = np.array([-3,0])
D = np.array([0,0])
poly = np.array([A,B,C,D,A])
ref = poly[:, [1,0]]
scaled = poly * 4
plt.plot(poly[:,0], poly[:,1], label="Original")
plt.plot(ref[:,0], ref[:,1], label="Reflection y=x")
plt.plot(scaled[:,0], scaled[:,1], label="Scaling x4")
plt.legend()
plt.title("Polygon Transformations")
plt.show()


