import numpy as np
import matplotlib.pyplot as plt
theta = np.linspace(0, 2*np.pi, 50)
x = 5 * np.cos(theta)
y = 5 * np.sin(theta)
plt.plot(x, y)
plt.title("Circle x^2 + y^2 = 25")
plt.xlabel("x")
plt.ylabel("y")
plt.gca().set_aspect('equal')
plt.show()
















































