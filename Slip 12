import numpy as np
import matplotlib.pyplot as plt
theta = np.linspace(0, 2*np.pi, 50)
x = 4 * np.cos(theta)
y = 4 * np.sin(theta)
plt.plot(x, y)
plt.title("Circle x^2 + y^2 = 16")
plt.xlabel("x")
plt.ylabel("y")
plt.gca().set_aspect('equal')
plt.show()


































