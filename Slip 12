Question 1-5

from sympy import Point, Polygon
from sympy import pi
A = Point(1,1)
B = Point(-1,1)
C = Point(-1,-1)
D = Point(1,-1)
poly = Polygon(A, B, C, D)
print("Angles at vertices:")
for angle in poly.angles.values():
    print(angle)
rotated = poly.rotate(pi/3)
print("Rotated Polygon:", rotated)




Question 2-1

import matplotlib.pyplot as plt
import numpy as np
P = np.array([1,3])
Q = np.array([3,3])
R = np.array([4,5])
triangle = np.array([P,Q,R,P])
ref1 = triangle[:, [1,0]]
ref2 = -triangle[:, [1,0]]
plt.plot(triangle[:,0], triangle[:,1], label="Original")
plt.plot(ref1[:,0], ref1[:,1], label="y = x")
plt.plot(ref2[:,0], ref2[:,1], label="y = -x")
plt.legend()
plt.title("Triangle Reflections")
plt.show()




