import matplotlib.pyplot as plt
import numpy as np
x_points = []
y_points = []
x_values = np.linspace(-5, 5, 100)
for x in x_values:
    y = (25 - x**2)**0.5   # upper semicircle
    x_points.append(x)
    y_points.append(y)
plt.plot(x_points, y_points, 'o')
y_points_lower = [-y for y in y_points]
plt.plot(x_points, y_points_lower, 'o')
plt.title("Circle: x^2 + y^2 = 25")
plt.axis('equal')
plt.grid()
plt.show()



